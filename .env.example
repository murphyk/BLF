# Required: OpenRouter API key (for all LLM calls via litellm)
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Required: Brave Search API key (for web search)
# Get one at https://brave.com/search/api/
BRAVE_API_KEY=your-key-here

# Optional: FRED API key (for FRED economic data tool)
# Get one at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your-key-here

# Optional: alternative search engines (only needed if you switch from Brave)
# SERPER_API_KEY=your-key-here
# GOOGLE_API_KEY=your-key-here
# PERPLEXITY_API_KEY=your-key-here
# EXA_API_KEY=your-key-here

# Optional: macOS SSL fix (only needed if you get SSL certificate errors)
# Find your certifi path with: python3 -c "import certifi; print(certifi.where())"
# SSL_CERT_FILE=/path/to/cacert.pem
